```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map
*.ts.map

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# Testing
.nyc_output/
coverage-final.json

# OS generated files
.DS_Store
Thumbs.db

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Node.js (if applicable)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled JavaScript (if applicable)
*.min.js
*.bundle.js

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```